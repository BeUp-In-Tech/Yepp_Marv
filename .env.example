# ==============================
# Core
# ==============================
PORT=3002
MONGO_URI=mongodb://127.0.0.1:27017/coupon-app
NODE_ENV=development

# ==============================
# JWT / OTP
# ==============================
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_ACCESS_EXPIRATION=1d
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_REFRESH_EXPIRATION=30d
OTP_JWT_ACCESS_SECRET=replace_with_secure_otp_secret
OTP_JWT_ACCESS_EXPIRATION=10m

# ==============================
# Security / App URLs
# ==============================
BCRYPT_SALT_ROUND=10
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3002
DEEP_LINK=yeppads://open
REQUEST_RATE_LIMIT=300
REQUEST_RATE_LIMIT_TIME=60
EXPRESS_SESSION_SECRET=replace_with_secure_session_secret

# ==============================
# Cloudinary
# ==============================
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET=your_cloudinary_api_secret

# ==============================
# Admin Seed
# ==============================
ADMIN_MAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword@123

# ==============================
# Redis
# ==============================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ==============================
# Email (SMTP)
# ==============================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=mailer@example.com
EMAIL_PASSWORD=replace_with_email_password
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=Coupon App

# ==============================
# Google OAuth
# ==============================
GOOGLE_OAUTH_ID=google_web_client_id
GOOGLE_OAUTH_SECRET=google_web_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3002/api/v1/auth/google/callback
GOOGLE_ANDROID_CLIENT_ID=google_android_client_id
GOOGLE_IOS_CLIENT_ID=google_ios_client_id

# ==============================
# Apple Sign-In
# ==============================
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_KEY\n-----END PRIVATE KEY-----"
APPLE_IOS_CLIENT_ID=com.example.ios
APPLE_WEB_CLIENT_ID=com.example.web
APPLE_WEB_REDIRECT_URI=http://localhost:3002/api/v1/auth/apple/callback

# ==============================
# Firebase Service Account
# ==============================
TYPE=service_account
PROJECT_ID=your_project_id
PRIVATE_KEY_ID=your_private_key_id
PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_KEY\n-----END PRIVATE KEY-----"
CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
CLIENT_ID=your_client_id
AUTH_URI=https://accounts.google.com/o/oauth2/auth
TOKEN_URI=https://oauth2.googleapis.com/token
AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...
UNIVERSE_DOMAIN=googleapis.com

# ==============================
# Stripe
# ==============================
STRIPE_SECRET_KEY=sk_test_replace_with_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_replace_with_webhook_secret

# ==============================
# Google Play IAP Validation (Optional but used by code path)
# ==============================
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project","private_key_id":"key_id","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"service-account@your-project.iam.gserviceaccount.com","client_id":"1234567890","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/...","universe_domain":"googleapis.com"}
