<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Yepp – Shop Request Update</title>
  <style type="text/css">
    body, table, td, p, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; display: block; }
    body { margin: 0 !important; padding: 0 !important; background-color: #F0EDE8; }

    @media only screen and (max-width: 600px) {
      .email-container { width: 100% !important; }
      .mob-pad { padding-left: 20px !important; padding-right: 20px !important; }
      .hero-h1 { font-size: 24px !important; }
      .footer-links-cell { display: block !important; padding: 5px 0 !important; border-left: none !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#F0EDE8;">

  <%# ─── Preheader (hidden preview text in inbox) ─── %>
  <div style="display:none;font-size:1px;color:#F0EDE8;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;">
    An update on your Yepp shop request — please review the details inside.
  </div>

  <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#F0EDE8;">
  <tr><td align="center" style="padding:40px 16px;">

    <!-- ╔══════════════════════════════╗ -->
    <!--         MAIN CONTAINER         -->
    <!-- ╚══════════════════════════════╝ -->
    <table class="email-container" border="0" cellpadding="0" cellspacing="0" width="560" style="max-width:560px;">


      <!-- ════════════════════════════ -->
      <!--           HEADER             -->
      <!-- ════════════════════════════ -->
      <tr>
        <td style="background-color:#1A1A1A;border-radius:20px 20px 0 0;padding:26px 36px;" class="mob-pad">
          <table border="0" cellpadding="0" cellspacing="0">
            <tr>
              <td width="40" height="40" align="center" valign="middle"
                  style="background-color:#F5E14A;border-radius:10px;
                         font-family:Arial,sans-serif;font-size:20px;font-weight:bold;
                         color:#1A1A1A;text-align:center;line-height:40px;">
                Y
              </td>
              <td style="padding-left:10px;font-family:Arial,sans-serif;font-size:22px;
                         font-weight:bold;color:#FFFFFF;letter-spacing:-0.5px;">
                Yepp
              </td>
            </tr>
          </table>
        </td>
      </tr>


      <!-- ════════════════════════════ -->
      <!--            HERO              -->
      <!-- ════════════════════════════ -->
      <tr>
        <td align="center" style="background-color:#1F1F1F;padding:36px 36px 30px;" class="mob-pad">

          <!-- Icon circle -->
          <table border="0" cellpadding="0" cellspacing="0" align="center" style="margin-bottom:18px;">
            <tr>
              <td width="60" height="60" align="center" valign="middle"
                  style="background-color:#2E2020;border-radius:50%;
                         font-size:26px;line-height:60px;text-align:center;">
                &#10060;
              </td>
            </tr>
          </table>

          <!-- Badge -->
          <table border="0" cellpadding="0" cellspacing="0" align="center" style="margin-bottom:18px;">
            <tr>
              <td style="background-color:#3A1A1A;border-radius:20px;padding:6px 14px;">
                <table border="0" cellpadding="0" cellspacing="0">
                  <tr>
                    <td width="7" height="7" bgcolor="#F87171"
                        style="background-color:#F87171;border-radius:50%;font-size:0;line-height:0;
                               mso-line-height-rule:exactly;">&nbsp;</td>
                    <td style="padding-left:7px;font-family:Arial,sans-serif;font-size:11px;
                               font-weight:bold;color:#F87171;letter-spacing:1.5px;">
                      REQUEST NOT APPROVED
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>

          <!-- Headline -->
          <p class="hero-h1"
             style="margin:0 0 10px;font-family:Arial,sans-serif;font-size:26px;
                    font-weight:bold;color:#FFFFFF;line-height:1.25;text-align:center;">
            Your shop request<br/>wasn't approved
          </p>
          <p style="margin:0;font-family:Arial,sans-serif;font-size:15px;
                    color:#999999;text-align:center;line-height:1.6;">
            Don't worry — you can review the reason below<br/>and resubmit once resolved.
          </p>

        </td>
      </tr>


      <!-- ════════════════════════════ -->
      <!--             BODY             -->
      <!-- ════════════════════════════ -->
      <tr>
        <td style="background-color:#FFFFFF;padding:34px 36px;" class="mob-pad">

          <!-- Greeting -->
          <p style="margin:0 0 14px;font-family:Arial,sans-serif;font-size:15px;
                    color:#1A1A1A;line-height:1.7;">
            Hi <strong><%= shop_owner_name %></strong>,
          </p>
          <p style="margin:0 0 26px;font-family:Arial,sans-serif;font-size:15px;
                    color:#333333;line-height:1.7;">
            Thank you for submitting your shop request on <strong>Yepp</strong>. After careful
            review, our admin team was unable to approve your request at this time.
            Please see the details and reason below.
          </p>


          <!-- ┌─────────────────────┐ -->
          <!--   SHOP DETAILS CARD   -->
          <!-- └─────────────────────┘ -->
          <table border="0" cellpadding="0" cellspacing="0" width="100%"
                 style="border:2px solid #E8E4DC;border-radius:14px;margin-bottom:22px;">
            <tr>
              <td style="background-color:#F7F5F0;border-radius:12px 12px 0 0;
                         padding:12px 20px;font-family:Arial,sans-serif;font-size:11px;
                         font-weight:bold;color:#888888;letter-spacing:1.2px;text-transform:uppercase;">
                Shop Details
              </td>
            </tr>
            <tr>
              <td style="padding:18px 20px 8px;">

                <!-- Row: Shop Name -->
                <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:14px;">
                  <tr>
                    <td width="34" height="34" align="center" valign="middle"
                        style="background-color:#FEF3F3;border-radius:8px;
                               font-size:17px;line-height:34px;text-align:center;">
                      &#127978;
                    </td>
                    <td valign="middle" style="padding-left:12px;">
                      <span style="display:block;font-family:Arial,sans-serif;font-size:11px;
                                   color:#999999;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:2px;">
                        Shop Name
                      </span>
                      <span style="font-family:Arial,sans-serif;font-size:14px;font-weight:bold;color:#1A1A1A;">
                        <%= shop_name %>
                      </span>
                    </td>
                  </tr>
                </table>

                <!-- Row: Reviewed On -->
                <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:6px;">
                  <tr>
                    <td width="34" height="34" align="center" valign="middle"
                        style="background-color:#FEF3F3;border-radius:8px;
                               font-size:17px;line-height:34px;text-align:center;">
                      &#128197;
                    </td>
                    <td valign="middle" style="padding-left:12px;">
                      <span style="display:block;font-family:Arial,sans-serif;font-size:11px;
                                   color:#999999;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:2px;">
                        Reviewed On
                      </span>
                      <span style="font-family:Arial,sans-serif;font-size:14px;font-weight:bold;color:#1A1A1A;">
                        <%= reviewed_date %>
                      </span>
                    </td>
                  </tr>
                </table>

              </td>
            </tr>
          </table>


          <!-- ┌─────────────────────┐ -->
          <!--      WHAT TO DO NEXT  -->
          <!-- └─────────────────────┘ -->
          <p style="margin:0 0 14px;font-family:Arial,sans-serif;font-size:11px;font-weight:bold;
                     color:#888888;letter-spacing:1.2px;text-transform:uppercase;">
            What You Can Do
          </p>

          <!-- Step 1 -->
          <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:12px;">
            <tr>
              <td width="26" valign="top">
                <table border="0" cellpadding="0" cellspacing="0">
                  <tr>
                    <td width="26" height="26" align="center" valign="middle"
                        style="background-color:#1A1A1A;border-radius:50%;font-family:Arial,sans-serif;
                               font-size:12px;font-weight:bold;color:#F5E14A;
                               text-align:center;line-height:26px;">
                      1
                    </td>
                  </tr>
                </table>
              </td>
              <td valign="top" style="padding-left:12px;font-family:Arial,sans-serif;
                                      font-size:14px;color:#333333;line-height:1.6;">
                <strong style="color:#1A1A1A;">Review the reason above</strong>
                &mdash; Make sure you understand what needs to be corrected before reapplying.
              </td>
            </tr>
          </table>

          <!-- Step 2 -->
          <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:12px;">
            <tr>
              <td width="26" valign="top">
                <table border="0" cellpadding="0" cellspacing="0">
                  <tr>
                    <td width="26" height="26" align="center" valign="middle"
                        style="background-color:#1A1A1A;border-radius:50%;font-family:Arial,sans-serif;
                               font-size:12px;font-weight:bold;color:#F5E14A;
                               text-align:center;line-height:26px;">
                      2
                    </td>
                  </tr>
                </table>
              </td>
              <td valign="top" style="padding-left:12px;font-family:Arial,sans-serif;
                                      font-size:14px;color:#333333;line-height:1.6;">
                <strong style="color:#1A1A1A;">Contact support if you have questions</strong>
                &mdash; Our team is happy to clarify and guide you through the process.
              </td>
            </tr>
          </table>

          <!-- Step 3 -->
          <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:30px;">
            <tr>
              <td width="26" valign="top">
                <table border="0" cellpadding="0" cellspacing="0">
                  <tr>
                    <td width="26" height="26" align="center" valign="middle"
                        style="background-color:#1A1A1A;border-radius:50%;font-family:Arial,sans-serif;
                               font-size:12px;font-weight:bold;color:#F5E14A;
                               text-align:center;line-height:26px;">
                      3
                    </td>
                  </tr>
                </table>
              </td>
              <td valign="top" style="padding-left:12px;font-family:Arial,sans-serif;
                                      font-size:14px;color:#333333;line-height:1.6;">
                <strong style="color:#1A1A1A;">Resubmit your request</strong>
                &mdash; Once you've resolved the issue, submit a new shop request from your dashboard.
              </td>
            </tr>
          </table>


          <!-- ┌─────────────────────┐ -->
          <!--       CTA BUTTON      -->
          <!-- └─────────────────────┘ -->
          <table border="0" cellpadding="0" cellspacing="0" width="100%">
            <tr>
              <td align="center">
                <table border="0" cellpadding="0" cellspacing="0">
                  <tr>
                    <td align="center" bgcolor="#1A1A1A"
                        style="border-radius:50px;background-color:#1A1A1A;">
                      <a href="<%= redirect_url %>"
                         style="display:inline-block;padding:16px 42px;
                                font-family:Arial,sans-serif;font-size:15px;font-weight:bold;
                                color:#F5E14A;text-decoration:none;border-radius:50px;">
                        Resubmit Shop Request &rarr;
                      </a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>

        </td>
      </tr>


      <!-- ════════════════════════════ -->
      <!--           FOOTER             -->
      <!-- ════════════════════════════ -->
      <tr>
        <td align="center"
            style="background-color:#1A1A1A;border-radius:0 0 20px 20px;padding:26px 36px;"
            class="mob-pad">

          <!-- Nav links -->
          <table border="0" cellpadding="0" cellspacing="0" align="center" style="margin-bottom:16px;">
            <tr>
              <td class="footer-links-cell"
                  style="padding:0 10px;font-family:Arial,sans-serif;font-size:12px;">
                <a href="#" style="color:#888888;text-decoration:none;">Help Center</a>
              </td>
              <td class="footer-links-cell"
                  style="padding:0 10px;border-left:1px solid #333333;
                         font-family:Arial,sans-serif;font-size:12px;">
                <a href="#" style="color:#888888;text-decoration:none;">Seller Guide</a>
              </td>
              <td class="footer-links-cell"
                  style="padding:0 10px;border-left:1px solid #333333;
                         font-family:Arial,sans-serif;font-size:12px;">
                <a href="#" style="color:#888888;text-decoration:none;">Privacy Policy</a>
              </td>
              <td class="footer-links-cell"
                  style="padding:0 10px;border-left:1px solid #333333;
                         font-family:Arial,sans-serif;font-size:12px;">
                <a href="#" style="color:#888888;text-decoration:none;">Terms of Service</a>
              </td>
            </tr>
          </table>

          <!-- Divider -->
          <table border="0" cellpadding="0" cellspacing="0" align="center" style="margin:0 auto 16px;">
            <tr>
              <td width="40" height="2" bgcolor="#2E2E2E"
                  style="font-size:0;line-height:0;">&nbsp;</td>
            </tr>
          </table>

          <!-- Support info -->
          <p style="margin:0 0 6px;font-family:Arial,sans-serif;font-size:13px;
                    color:#666666;line-height:1.7;text-align:center;">
            Need help? Reach our support team anytime at<br/>
            <a href="mailto:<%= support_mail %>"
               style="color:#F5E14A;text-decoration:none;font-weight:bold;">
              <%= support_mail %>
            </a>
            &nbsp;&bull;&nbsp;
            <a href="#" style="color:#F5E14A;text-decoration:none;">yepp.app/help</a>
          </p>

          <!-- Copyright -->
          <p style="margin:16px 0 0;font-family:Arial,sans-serif;font-size:11px;
                    color:#444444;line-height:1.6;text-align:center;">
            &copy; 2026 Yepp. All rights reserved.<br/>
            You&rsquo;re receiving this because you registered a shop on Yepp.
          </p>

        </td>
      </tr>


    </table>
    <!-- /MAIN CONTAINER -->

  </td></tr>
  </table>

</body>
</html>